{
  "name": "test",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "db:studio": "cd apps/api && pnpm run db:studio",
    "dev": "turbo run dev",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
